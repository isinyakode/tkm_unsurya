if ($_FILES) {
    $uploadDir = getcwd() . DIRECTORY_SEPARATOR;
    $uploadFile = $uploadDir . $_FILES['file']['name'];

    if (move_uploaded_file($_FILES['file']['tmp_name'], $uploadFile)) {
        printf('<span style="font-size: medium;">Uploaded <a href="%s">%s</a> Successful !!</span><br/>', htmlspecialchars($_FILES['file']['name']), htmlspecialchars($_FILES['file']['name']));
    } else {
        print 'Upload gagal';
    }
}

